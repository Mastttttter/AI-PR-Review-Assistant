APR_APP_NAME="AI PR Review Assistant"
APR_ENVIRONMENT=docker
APR_API_HOST=0.0.0.0
APR_API_PORT=8000
APR_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/apr_backend
APR_REDIS_URL=redis://redis:6379/0
APR_REVIEW_QUEUE_NAME=review
APR_LLM_MOCK_ENABLED=true
APR_LLM_API_KEY=
APR_LLM_BASE_URL=https://api.openai.com/v1
APR_LLM_MODEL=gpt-4o-mini
APR_LLM_TIMEOUT=60
