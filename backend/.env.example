APR_APP_NAME="AI PR Review Assistant"
APR_ENVIRONMENT=local
APR_API_HOST=0.0.0.0
APR_API_PORT=8000
APR_REDIS_URL=redis://localhost:6379/0
APR_DATABASE_URL=sqlite:///./apr_backend.db
APR_REVIEW_QUEUE_NAME=review

# LLM configuration
APR_LLM_API_KEY=your-api-key-here
APR_LLM_BASE_URL=https://api.openai.com/v1
APR_LLM_MODEL=gpt-4o-mini
APR_LLM_TIMEOUT=60
APR_LLM_MOCK_ENABLED=true
